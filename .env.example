# Zoho OAuth Application Details
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here

# Notes:
# Make sure these credentials correspond to your self-client or server-based client in Zoho Developer Console (api-console.zoho.in)
# The scope of the refresh token MUST include at minimum 'ZohoCRM.modules.leads.CREATE'
